# ============================================================================
# SSP (System Scaling Performance) Project - Git Ignore Rules
# ============================================================================

# ── C/C++ Build Artifacts ─────────────────────────────────────────────────────
# Object files
*.o
*.obj
*.a
*.lib
*.so
*.dylib
*.dll

# Build directory (from Makefile)
obj/
build/
dist/

# Compiled executables (project-specific)
load_generator
benchmark
analysis
microarch
*.out
*.exe

# ── LaTeX build artifacts ─────────────────────────────────────────────────────
report/*.aux
report/*.bbl
report/*.blg
report/*.fdb_latexmk
report/*.fls
report/*.log
report/*.out
report/*.synctex.gz
report/*.toc
report/*.lof
report/*.lot
report/*.nav
report/*.snm
report/*.vrb
report/*.bcf
report/*.run.xml

# Keep the compiled PDF and source
!report/*.pdf
!report/*.tex

# IEEEtran.cls was downloaded locally — don't commit it (it's a third-party file)
report/IEEEtran.cls

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
*.whl

# Virtual environments
.venv/
venv/
env/
.env

# Jupyter / IPython
.ipynb_checkpoints/
*.ipynb

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*~
*.swp
*.swo

# ── VS Code ───────────────────────────────────────────────────────────────────
# Keep workspace settings (recipes, etc.) but ignore user-specific state
.vscode
.vscode/*.code-workspace

# ── Benchmark results (raw CSVs) ──────────────────────────────────────────────
# Uncomment the line below if you do NOT want to commit raw results
# results/*.csv

# ── Misc ──────────────────────────────────────────────────────────────────────
*.tmp
*.bak
core
core.*
*.stackdump
*.swp
*.swo
*~
\#*\#
.\#*

# ── Profiling and Performance Analysis ────────────────────────────────────────
*.prof
*.perf
gprof.out
callgrind.out.*
cachegrind.out.*
perf.data
perf.data.old

# ── IDE and Editor Files ──────────────────────────────────────────────────────
# VS Code
.vscode/
.vscode/*.code-workspace

# JetBrains IDEs
.idea/
*.iml
*.iws
*.ipr

# Other editors
*.sublime-project
*.sublime-workspace
.vim
.emacs*
*~
.classpath
.project
.c9/

# ── Debugger and Analysis Tools ───────────────────────────────────────────────
.ccls-cache/
.clangd/
compile_commands.json

# ── System and OS Files ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.Spotlight-V100
.Trashes
ehthumbs.db
.AppleDouble
.LSOverride
*.swp
*.swo
